// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

// ── NextAuth Required Models ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App Models ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for Google OAuth users
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  tccs     Tcc[]
}

model Tcc {
  id          String    @id @default(cuid())
  userId      String
  title       String
  course      String
  institution String
  workType    String?   // TCC | Monografia | Dissertação | Artigo Científico
  norma       String?   // ABNT | APA | Vancouver | Chicago | Outra
  deadline    DateTime?
  objective   String?   @db.Text
  status      TccStatus @default(IN_PROGRESS)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  attachments Attachment[]
}

model Message {
  id        String      @id @default(cuid())
  tccId     String
  role      MessageRole
  content   String      @db.Text
  agent     String?     // 'bibliotecario' | 'arquiteto' | 'redator'
  createdAt DateTime    @default(now())

  tcc Tcc @relation(fields: [tccId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  tccId     String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  tcc Tcc @relation(fields: [tccId], references: [id], onDelete: Cascade)
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  VIP
}

enum TccStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum MessageRole {
  user
  bot
}
